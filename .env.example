NEXT_PUBLIC_SANITY_PROJECT_ID=your_sanity_project_id
NEXT_PUBLIC_SANITY_DATASET=production

# Resend Email Service
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key_here

# Contact Form Email Recipient
# The email address where contact form submissions will be sent
CONTACT_EMAIL=your-email@example.com

# Careers Form Email Recipient (optional - falls back to CONTACT_EMAIL)
# The email address where job applications will be sent
CAREERS_EMAIL=your-email@example.com
